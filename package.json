{
  "name": "@naster3/google-forms-mcp",
  "version": "1.0.0",
  "description": "MCP server for reading and editing Google Forms with the official Google Forms and Google Drive APIs.",
  "packageManager": "pnpm@10.17.1",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "google-forms-mcp": "./bin/google-forms-mcp.js"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "dist/src/",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "ui": "tsx src/ui/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "prepack": "pnpm run build",
    "test": "node scripts/test-package.mjs",
    "auth": "node scripts/auth-package.mjs",
    "professionalize:web-form": "node scripts/professionalize-web-form-package.mjs",
    "apply:design-images": "node scripts/apply-design-images-package.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "google-forms",
    "google-drive",
    "typescript",
    "codex",
    "claude",
    "cline",
    "developer-tools"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "dotenv": "^16.6.1",
    "google-auth-library": "^10.4.1",
    "googleapis": "^150.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
